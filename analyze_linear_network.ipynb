    "L = 50\n",
    "PR_l = []\n",
    "for A in range(1, L//2-1):\n",
    "    Sigma = np.zeros((2*A+1+L,L))\n",
    "    a = 2/(2*A+1+L)\n",
    "    lamb = np.concatenate([np.ones(A+1)*a, np.ones(L-2*A-1)*(-a/2), np.ones(A)*a])\n",
    "\n",
    "    for i in range(1,L):\n",
    "        Sigma[i] = np.roll(lamb, i)\n",
    "    Sigma[L:,:] = a/2\n",
    "    # plt.imshow(Sigma)\n",
    "    # plt.show()\n",
    "    U, S, V = np.linalg.svd(Sigma)\n",
    "    PR_l.append(S.sum()**2/np.sum(S**2))\n",
    "    # plt.plot(S)\n",
    "    # plt.show()\n",
    "    # plt.plot(U[:,0])\n",
    "    # plt.show()\n",
    "plt.plot(PR_l)\n",
    "plt.show()\n"
   ]
